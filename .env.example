# --- Required infrastructure ---
DATABASE_URL=postgresql://user:pass@host:5432/nomad
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
INTERNAL_AGENT_SECRET=change-me-to-a-long-random-string

# --- Tool API keys ---
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
TAVILY_API_KEY=your-tavily-api-key

# --- Per-role LLM provider/model selection ---
# Research agents: swap to cerebras (1M TPD free) or google to avoid Groq 100k TPD cap
LLM_YOUTUBE_PROVIDER=groq
LLM_YOUTUBE_MODEL=llama-3.3-70b-versatile
LLM_REDDIT_PROVIDER=groq
LLM_REDDIT_MODEL=llama-3.3-70b-versatile
LLM_GOOGLE_PROVIDER=groq
LLM_GOOGLE_MODEL=llama-3.3-70b-versatile
# Synthesizer: quality-critical. Cerebras 235B (free 1M tok/day) >> 70B, with a
# Groq-70B fallback so a free-tier queue/error never hard-fails the trip.
LLM_SYNTH_PROVIDER=cerebras
LLM_SYNTH_MODEL=qwen-3-235b-a22b-instruct-2507
LLM_SYNTH_FALLBACK_PROVIDER=groq
LLM_SYNTH_FALLBACK_MODEL=llama-3.3-70b-versatile

# Cerebras examples — 1M TPD free tier, ~2000 tok/s. Available models:
#   llama3.1-8b                       (fast, reliable, smaller quality)
#   qwen-3-235b-a22b-instruct-2507    (best quality, may queue at free-tier peak hours)
# LLM_REDDIT_PROVIDER=cerebras
# LLM_REDDIT_MODEL=qwen-3-235b-a22b-instruct-2507
# LLM_YOUTUBE_PROVIDER=cerebras
# LLM_YOUTUBE_MODEL=qwen-3-235b-a22b-instruct-2507
# LLM_GOOGLE_PROVIDER=cerebras
# LLM_GOOGLE_MODEL=qwen-3-235b-a22b-instruct-2507

# --- Provider API keys (set only the ones you use) ---
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
CEREBRAS_API_KEY=

# --- Optional observability ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=
